# ─────────────────────────────────────────────────────────────
# deeno — секреты и рантайм-данные (НИКОГДА не коммитить).
# Код ядра, тем, плагинов и документация — трекаются как обычно.
# ─────────────────────────────────────────────────────────────

# Конфиг сайта (может содержать smtp_pass); создаётся установщиком.
# Шаблон — config.sample.json — трекается.
/config.php
/config.json

# Секрет приложения (HMAC-подпись токенов) и данные безопасности.
/system/secret.key
/system/security-data.php
# Файлы блокировки (DataFile::update, StatsManager) — чистый рантайм,
# создаются рядом с данными и живут ровно на время записи
*.lock
/system/security.json

# Рантайм-данные конкретной установки (создаются при работе, не при установке):
# метаданные категорий (guard-файл) и 301-редиректы при смене slug/категории.
/system/categories.php
/system/redirects.json

# Логи (создаются в рантайме).
/system/logs/*
!/system/logs/.gitkeep

# Файлы сессий админки (создаются в рантайме, каталог — самим Security).
/system/sessions/

# Аккаунты пользователей: bcrypt-хеши + email. Создаются установщиком.
/users/*
!/users/.gitkeep

# Резервные копии сайта.
/backups/*
!/backups/.gitkeep

# Загруженные медиафайлы (папка сохраняется, содержимое — нет).
/media/*
!/media/.gitkeep

# Кэш рендера, индекс постов и статистика просмотров.
/cache/*
!/cache/.gitkeep

# Контент сайта: посты и страницы (пользовательские .md).
# Папки сохраняются пустыми, содержимое — не коммитим.
/content/posts/*
!/content/posts/.gitkeep
/content/pages/*
!/content/pages/.gitkeep

# ── Системный/редакторский мусор ──
.DS_Store
Thumbs.db
*.swp
*.swo
._*

# ── Временные файлы разработки ──
/_*.html

# ── Внутренние рабочие документы (не для публичного репозитория) ──
# Остаются локально; публикуется только пользовательская документация
# (README, UserDoc/, .github/SECURITY.md, .github/CONTRIBUTING.md).
/DevDoc/
/CLAUDE.md

# Рабочая папка: скриншоты, исходники логотипа, чужие проекты, черновики.
# Витринные картинки README живут в /docs/ и трекаются отдельно.
/WorkFiles/

# Русские оригиналы документации. Публикуется английская версия (UserDoc/*.md);
# русские копии остаются локально для сверки при переводе.
/UserDoc/ru/

# Тема «БайдароШная» — сайт конкретного клиента, к deeno отношения не имеет
# (решение 2026-07-20). Живёт только в рабочей копии и на боевом хостинге.
/themes/baydaroshnaya/
/baydaroshnaya/
